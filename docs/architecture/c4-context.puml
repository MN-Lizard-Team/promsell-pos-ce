@startuml C4_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Promsell POS CE — System Context

Person(merchant, "Merchant", "Small shop owner / cashier\nuses phone or tablet")

System(promsell, "Promsell POS CE", "Offline-first mobile POS\nFlutter + SQLite (Drift)")

System_Ext(printer, "Thermal Printer", "Bluetooth / USB (future)")
System_Ext(os_share, "OS Share Sheet", "PDF export via system share")

Rel(merchant, promsell, "Manages sales, products,\ninventory, reports")
Rel(promsell, os_share, "Share/Print receipt PDF")
Rel_R(promsell, printer, "Print receipt (future)")

SHOW_LEGEND()
@enduml
