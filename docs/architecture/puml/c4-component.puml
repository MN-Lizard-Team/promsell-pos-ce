@startuml C4_Component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Promsell POS CE — Component Diagram (Sale Feature) v0.8.4

Container_Boundary(sale_feature, "Sale Feature") {
    Component(sale_page, "SalePage", "Flutter Widget", "Product catalog + cart + discount dialog + drafts sheet")
    Component(payment_sheet, "PaymentSheet", "Flutter Widget", "Payment method, breakdown, cash input, confirm")
    Component(cart_bloc, "CartBloc", "flutter_bloc", "Cart state + discount")
    Component(draft_bloc, "DraftBloc", "flutter_bloc", "Draft auto-save (1.5s debounce)")
    Component(checkout_bloc, "CheckoutBloc", "flutter_bloc", "Checkout + payment confirmation")
    Component(create_sale_uc, "CreateSale", "Use Case", "Delegates to SaleRepository")
    Component(void_sale_uc, "VoidSale", "Use Case", "Delegates to SaleRepository")
    Component(sale_repo, "SaleRepository", "Interface", "Abstract contract")
    Component(sale_repo_impl, "SaleRepositoryImpl", "Implementation", "Delegates to datasource")
    Component(sale_ds, "SaleLocalDatasource", "Drift DAO", "Atomic insert + void transactions + discount writes")
    Component(receipt_svc, "ReceiptNumberService", "Service", "YYMMDD-XX-NNNN generation")
    Component(inv_log_svc, "InventoryLogService", "Service", "Audit trail logging")
    Component(draft_repo, "DraftCartRepository", "Interface", "Abstract draft persistence contract")
    Component(draft_repo_impl, "DraftCartRepositoryImpl", "Implementation", "Delegates to draft datasource")
    Component(draft_ds, "DraftCartLocalDatasource", "Drift DAO", "Upsert / load draft_carts + draft_cart_items")
}

ContainerDb(db, "SQLite", "Drift", "sales + sale_items + inventory_logs + app_settings + draft_carts + draft_cart_items + daily_closes")

Rel(sale_page, cart_bloc, "add events (cart, discount)")
Rel(sale_page, draft_bloc, "draft events")
Rel(payment_sheet, checkout_bloc, "CheckoutConfirmed (with discount params)")
Rel(checkout_bloc, create_sale_uc, "call")
Rel(draft_bloc, draft_repo, "saveDraft / loadDraft / deleteDraft")
Rel(create_sale_uc, sale_repo, "call")
Rel(sale_repo, sale_repo_impl, "implements")
Rel(sale_repo_impl, sale_ds, "delegates")
Rel(draft_repo, draft_repo_impl, "implements")
Rel(draft_repo_impl, draft_ds, "delegates")
Rel(sale_ds, receipt_svc, "nextReceiptNumber()")
Rel(sale_ds, inv_log_svc, "logSale()")
Rel(sale_ds, db, "transaction")
Rel(receipt_svc, db, "read/write app_settings")
Rel(inv_log_svc, db, "insert inventory_logs")
Rel(draft_ds, db, "upsert draft_carts + draft_cart_items")

SHOW_LEGEND()
@enduml
